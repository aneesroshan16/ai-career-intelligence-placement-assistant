{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "env": {
    "VITE_API_BASE_URL": "@career_intel_api_base_url",
    "VITE_SUPABASE_URL": "@career_intel_supabase_url",
    "VITE_SUPABASE_ANON_KEY": "@career_intel_supabase_anon_key"
  }
}
