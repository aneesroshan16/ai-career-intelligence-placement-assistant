# --- App ---
ENVIRONMENT=local
DEBUG=true

# --- Database (Supabase Postgres connection string, asyncpg driver) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/career_intel

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=resumes

# --- Auth mode: "supabase" for production, "dev" for local testing without a live Supabase project ---
AUTH_MODE=dev
DEV_JWT_SECRET=dev-only-secret-do-not-use-in-prod

# --- AI Providers: mock | openai | gemini ---
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Caching (optional — omit to use in-memory cache) ---
REDIS_URL=

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173"]

# --- Logging ---
LOG_LEVEL=INFO
